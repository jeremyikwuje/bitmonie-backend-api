{
  "name": "bitmonie-api",
  "version": "1.0.0",
  "description": "Bitmonie — crypto-backed instant Naira credit (Lightning MVP)",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/src/main",
    "worker:price-feed": "ts-node -r dotenv/config -r tsconfig-paths/register workers/price-feed.worker.ts",
    "worker:liquidation": "ts-node -r dotenv/config -r tsconfig-paths/register workers/liquidation-monitor.worker.ts",
    "worker:loan-expiry": "ts-node -r dotenv/config -r tsconfig-paths/register workers/loan-expiry.worker.ts",
    "worker:loan-reminder": "ts-node -r dotenv/config -r tsconfig-paths/register workers/loan-reminder.worker.ts",
    "worker:disbursement-digest": "ts-node -r dotenv/config -r tsconfig-paths/register workers/disbursement-on-hold-digest.worker.ts",
    "worker:outflow-reconciler": "ts-node -r dotenv/config -r tsconfig-paths/register workers/outflow-reconciler.worker.ts",
    "worker:scheduler": "ts-node -r dotenv/config -r tsconfig-paths/register workers/scheduler.worker.ts",
    "worker:price-feed:prod": "node dist/workers/price-feed.worker.js",
    "worker:liquidation:prod": "node dist/workers/liquidation-monitor.worker.js",
    "worker:loan-expiry:prod": "node dist/workers/loan-expiry.worker.js",
    "worker:loan-reminder:prod": "node dist/workers/loan-reminder.worker.js",
    "worker:disbursement-digest:prod": "node dist/workers/disbursement-on-hold-digest.worker.js",
    "worker:outflow-reconciler:prod": "node dist/workers/outflow-reconciler.worker.js",
    "worker:scheduler:prod": "node dist/workers/scheduler.worker.js",
    "worker:all": "concurrently -n price,liq,reconcile,sched -c green,yellow,red,cyan \"pnpm worker:price-feed\" \"pnpm worker:liquidation\" \"pnpm worker:outflow-reconciler\" \"pnpm worker:scheduler\"",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest --config jest.config.ts --selectProjects unit",
    "test:watch": "jest --config jest.config.ts --selectProjects unit --watch",
    "test:integration": "jest --config jest.config.ts --selectProjects integration --runInBand",
    "test:e2e": "jest --config jest.config.ts --selectProjects e2e --runInBand",
    "test:cov": "jest --config jest.config.ts --selectProjects unit --coverage",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "ops:create-user": "ts-node -r dotenv/config -r tsconfig-paths/register scripts/create-ops-user.ts",
    "ops:disable-user": "ts-node -r dotenv/config -r tsconfig-paths/register scripts/disable-ops-user.ts",
    "ops:restore-bad-liquidations": "ts-node -r dotenv/config -r tsconfig-paths/register scripts/restore-bad-rate-liquidations.ts",
    "ops:replay-dropped-collections": "ts-node -r dotenv/config -r tsconfig-paths/register scripts/replay-dropped-palmpay-collections.ts"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.6",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.6",
    "@nestjs/platform-express": "^10.4.6",
    "@nestjs/swagger": "^8.0.7",
    "@nestjs/throttler": "^6.2.1",
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "@types/qrcode": "^1.5.6",
    "argon2": "^0.41.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "cookie-parser": "^1.4.7",
    "decimal.js": "^10.4.3",
    "helmet": "^8.0.0",
    "ioredis": "^5.4.1",
    "nestjs-pino": "^4.1.0",
    "node-forge": "^1.4.0",
    "otplib": "^13.4.0",
    "pg": "^8.20.0",
    "pino-http": "^10.3.0",
    "qrcode": "^1.5.4",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.7",
    "@nestjs/schematics": "^10.2.3",
    "@nestjs/testing": "^10.4.6",
    "@types/cookie-parser": "^1.4.7",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.9.0",
    "@types/node-forge": "^1.3.14",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^6.0.2",
    "concurrently": "^9.2.1",
    "dotenv": "^17.4.2",
    "jest": "^29.7.0",
    "jest-mock-extended": "^3.0.7",
    "pino-pretty": "^11.3.0",
    "prisma": "^7.7.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "@prisma/client",
      "@prisma/engines",
      "argon2",
      "prisma"
    ]
  }
}
