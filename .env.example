# ── Application ───────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
API_BASE_URL=http://localhost:3000
ALLOWED_ORIGIN=http://localhost:3000

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://bitmonie:bitmonie@localhost:55432/bitmonie_db

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:56379

# ── Auth ──────────────────────────────────────────────────────────────────────
SESSION_SECRET=                            # 32 random bytes hex — rotate quarterly
ENCRYPTION_KEY=                            # 32 bytes hex — AES-256 for BVN/NIN

# ── Provider Selection — change the value here to swap providers at runtime ───
# Each value must match the key used in providers.config.ts
PRICE_FEED_PROVIDER=quidax
COLLATERAL_PROVIDER=blink
DISBURSEMENT_PROVIDER=palmpay
# KYC tier→provider mapping is set in src/config/kyc.config.ts (KYC_TIER_CONFIG)
# Email provider is set in src/config/email.config.ts (EMAIL_PROVIDER_CONFIG)

# ── Quidax (Price Feed) ───────────────────────────────────────────────────────
QUIDAX_API_KEY=
QUIDAX_BASE_URL=https://app.quidax.io/api/v1

# ── Blink / Galoy (Collateral — v1 Lightning) ─────────────────────────────────
BLINK_API_KEY=
BLINK_BASE_URL=https://api.blink.sv
BLINK_WEBHOOK_SECRET=

# ── Palmpay (Disbursement — v1) ───────────────────────────────────────────────
PALMPAY_API_KEY=
PALMPAY_SECRET_KEY=
PALMPAY_BASE_URL=
PALMPAY_WEBHOOK_SECRET=
PALMPAY_WEBHOOK_IP_ALLOWLIST=             # comma-separated IPs

# ── Qore ID (KYC) ─────────────────────────────────────────────────────────────
QOREID_CLIENT_ID=
QOREID_CLIENT_SECRET=
QOREID_BASE_URL=

# ── Dojah (KYC — alternative to Qore ID) ─────────────────────────────────────
DOJAH_APP_ID=
DOJAH_API_KEY=

# ── Email (shared sender identity across all providers) ───────────────────────
EMAIL_FROM_ADDRESS=noreply@bitmonie.com
EMAIL_FROM_NAME=Bitmonie

# ── Mailgun ───────────────────────────────────────────────────────────────────
MAILGUN_API_KEY=
MAILGUN_DOMAIN=                              # e.g. mg.bitmonie.com
MAILGUN_REGION=us                            # us | eu

# ── Resend ────────────────────────────────────────────────────────────────────
RESEND_API_KEY=

# ── Postmark ──────────────────────────────────────────────────────────────────
POSTMARK_SERVER_TOKEN=
POSTMARK_MESSAGE_STREAM=outbound

# ── Worker Intervals ──────────────────────────────────────────────────────────
WORKER_PRICE_FEED_INTERVAL_MS=30000             # 30s
WORKER_LIQUIDATION_INTERVAL_MS=30000            # 30s
WORKER_PAYMENT_REQUEST_EXPIRY_INTERVAL_MS=60000 # 60s

# ── Observability ─────────────────────────────────────────────────────────────
LOG_LEVEL=info
INTERNAL_ALERT_EMAIL=ops@bitmonie.com
