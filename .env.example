# ── Application ──────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
API_BASE_URL=http://localhost:3000
ALLOWED_ORIGIN=http://localhost:3000

# ── Database ─────────────────────────────────────────────────────
DATABASE_URL=postgresql://bitmonie:bitmonie@localhost:55432/bitmonie_db

# ── Redis ────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:56379

# ── Auth ─────────────────────────────────────────────────────────
SESSION_SECRET=                            # 32 random bytes hex — rotate quarterly
ENCRYPTION_KEY=                            # 32 bytes hex — AES-256 for BVN/NIN

# ── Monierate (Price Feed) ────────────────────────────────────────
MONIERATE_API_KEY=
MONIERATE_BASE_URL=https://api.monierate.com

# ── Collateral Provider (Blink / Galoy — v1) ─────────────────────
COLLATERAL_PROVIDER_API_KEY=
COLLATERAL_PROVIDER_BASE_URL=https://api.blink.sv
COLLATERAL_PROVIDER_WEBHOOK_SECRET=

# ── Disbursement Provider (Palmpay — v1) ─────────────────────────
DISBURSEMENT_PROVIDER_API_KEY=
DISBURSEMENT_PROVIDER_SECRET_KEY=
DISBURSEMENT_PROVIDER_BASE_URL=
DISBURSEMENT_PROVIDER_WEBHOOK_SECRET=
DISBURSEMENT_PROVIDER_WEBHOOK_IP_ALLOWLIST=     # Comma-separated IPs

# ── KYC Provider (Qore ID) ───────────────────────────────────────
KYC_PROVIDER_CLIENT_ID=
KYC_PROVIDER_CLIENT_SECRET=
KYC_PROVIDER_BASE_URL=

# ── Worker Intervals ─────────────────────────────────────────────
WORKER_PRICE_FEED_INTERVAL_MS=30000             # 30s
WORKER_LIQUIDATION_INTERVAL_MS=30000            # 30s
WORKER_PAYMENT_REQUEST_EXPIRY_INTERVAL_MS=60000 # 60s

# ── Observability ─────────────────────────────────────────────────
LOG_LEVEL=info
INTERNAL_ALERT_EMAIL=ops@bitmonie.com
