      "name": "5. Loans",
      "item": [
        {
          "name": "POST /v1/loans/checkout",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const body = pm.response.json();",
                  "const id = body.loan_id ?? body.id;",
                  "if (id) {",
                  "  pm.collectionVariables.set('loan_id', id);",
                  "  console.log('loan_id captured:', id);",
                  "}",
                  "const hash = body.payment_request?.receiving_address ?? body.receiving_address ?? body.payment_hash;",
                  "if (hash) {",
                  "  pm.collectionVariables.set('payment_hash', hash);",
                  "  console.log('payment_hash captured:', hash);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"principal_ngn\": 300000,\n  \"duration_days\": 7,\n  \"disbursement_account_id\": \"{{disbursement_account_id}}\",\n  \"collateral_release_address\": \"jeremy@blink.sv\"\n}"
            },
            "url": { "raw": "{{base_url}}/v1/loans/checkout", "host": ["{{base_url}}"], "path": ["v1", "loans", "checkout"] },
            "description": "Creates loan + Lightning invoice via Blink. Status begins PENDING_COLLATERAL. Test script captures `loan_id` and `payment_hash` (Lightning payment hash = Blink webhook matching key).\n\n- `principal_ngn`: 50,000 – 10,000,000 (self-serve cap)\n- `duration_days`: 1 – 30\n- `disbursement_account_id`: optional, falls back to default\n- `collateral_release_address`: optional Lightning address for refund if loan expires"
          }
        },
